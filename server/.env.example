# ===========================================
# Server Configuration
# ===========================================
NODE_ENV=development
PORT=5000

# ===========================================
# CORS Configuration
# ===========================================
CLIENT_URL=http://localhost:3000

# ===========================================
# MongoDB Configuration
# ===========================================
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/advadev

# MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/advadev?retryWrites=true&w=majority

# ===========================================
# Email Service Configuration (SMTP)
# ===========================================
# For Gmail:
# 1. Enable 2FA on your Google account
# 2. Generate an app password: https://myaccount.google.com/apppasswords
# 3. Use the app password as SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@advadev.com

# Admin email to receive contact form submissions
ADMIN_EMAIL=hello@advadev.com

# ===========================================
# Optional: SendGrid Configuration
# ===========================================
# Uncomment and use SendGrid if preferred over SMTP
# SENDGRID_API_KEY=your-sendgrid-api-key

# ===========================================
# Rate Limiting
# ===========================================
# Contact form rate limit (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
